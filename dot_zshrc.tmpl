# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="powerlevel10k/powerlevel10k"

plugins=(
  git
  fzf
  zsh-autosuggestions
  zsh-syntax-highlighting
)

if [ -f "$ZSH/oh-my-zsh.sh" ]; then
  source "$ZSH/oh-my-zsh.sh"
fi

{{- if eq .chezmoi.os "darwin" }}
export PATH="/opt/homebrew/opt/node@20/bin:/opt/homebrew/bin:$PATH"

# Google Cloud SDK
if [ -f "$HOME/google-cloud-sdk/path.zsh.inc" ]; then . "$HOME/google-cloud-sdk/path.zsh.inc"; fi
if [ -f "$HOME/google-cloud-sdk/completion.zsh.inc" ]; then . "$HOME/google-cloud-sdk/completion.zsh.inc"; fi
export PATH="/opt/homebrew/share/google-cloud-sdk/bin:$PATH"
{{- end }}

{{- if eq .chezmoi.os "linux" }}
# Linux-specific PATH
export PATH="$HOME/.local/bin:$PATH"
{{- end }}

# Shared config
. "$HOME/.local/bin/env"

# Aliases
{{- if eq .chezmoi.os "darwin" }}
alias rd="bash ~/Desktop/System\ Scripts/research-dashboard.sh"
alias slog='open "postgresql://huangshifeng@localhost/surgery_log"'
alias bkup="bash ~/bin/backup_desktop_to_gdrive.sh"
alias todo="bash ~/.todo/show-dashboard.sh"
alias pelv="cd ~/Desktop/Research/Difficulty_Prediction/Auto_Pelvimetry_PyPI"
alias vdi="bash ~/Desktop/System\ Scripts/connect-vdi.sh"
{{- end }}

# >>> conda initialize >>>
# !! Contents within this block are managed by 'conda init' !!
{{- if eq .chezmoi.os "darwin" }}
__conda_setup="$('/opt/anaconda3/bin/conda' 'shell.zsh' 'hook' 2> /dev/null)"
{{- else }}
__conda_setup="$("$HOME/anaconda3/bin/conda" 'shell.zsh' 'hook' 2> /dev/null)"
{{- end }}
if [ $? -eq 0 ]; then
    eval "$__conda_setup"
else
{{- if eq .chezmoi.os "darwin" }}
    if [ -f "/opt/anaconda3/etc/profile.d/conda.sh" ]; then
        . "/opt/anaconda3/etc/profile.d/conda.sh"
    else
        export PATH="/opt/anaconda3/bin:$PATH"
    fi
{{- else }}
    if [ -f "$HOME/anaconda3/etc/profile.d/conda.sh" ]; then
        . "$HOME/anaconda3/etc/profile.d/conda.sh"
    else
        export PATH="$HOME/anaconda3/bin:$PATH"
    fi
{{- end }}
fi
unset __conda_setup
# <<< conda initialize <<<
{{ if eq .chezmoi.os "darwin" }}
# 痔瘡AI衛教研究專案
alias hemo="cd ~/Desktop/Research/AI_Clinical/痔瘡AI衛教 && claude --dangerously-skip-permissions"
{{- end }}

# ── Modern CLI tools (eza/bat/zoxide/atuin/lazygit/lazydocker/gh-dash) ──
if command -v eza >/dev/null 2>&1; then
  alias ls='eza --icons --group-directories-first'
  alias ll='eza -l --icons --group-directories-first --git'
  alias la='eza -la --icons --group-directories-first --git'
  alias lt='eza --tree --level=2 --icons --group-directories-first'
  alias l='eza -lah --icons --group-directories-first --git'
fi
command -v bat    >/dev/null 2>&1 && { export BAT_THEME="ansi"; alias catp='bat --style=plain --paging=never'; }
command -v zoxide >/dev/null 2>&1 && eval "$(zoxide init zsh)"
command -v atuin  >/dev/null 2>&1 && eval "$(atuin init zsh)"
command -v lazygit    >/dev/null 2>&1 && alias lg='lazygit'
command -v lazydocker >/dev/null 2>&1 && alias lzd='lazydocker'
alias ghd='gh dash'
{{ if eq .chezmoi.os "darwin" }}
# ── 安全網: 互動式 rm 改丟垃圾桶(可救回)。腳本用 /bin/rm 不受影響。永久刪用 \rm 或 command rm。
rm() {
  emulate -L zsh
  local -a paths; local a
  for a in "$@"; do [[ "$a" == -* ]] || paths+=("$a"); done
  if (( ${#paths} == 0 )); then echo "rm→垃圾桶: 未指定檔案(flags 已忽略)"; return 1; fi
  /usr/bin/trash "${paths[@]}" && echo "→ 已移到垃圾桶(可救回): ${paths[*]}"
}
{{- end }}

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
