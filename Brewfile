# Brewfile — modern dev CLI/TUI toolset.
# Reinstall on a new machine:  brew bundle --file=Brewfile
brew "eza"          # better ls
brew "bat"          # better cat
brew "zoxide"       # smarter cd (z)
brew "atuin"        # searchable shell history
brew "fzf"          # fuzzy finder
brew "lazygit"      # git TUI
brew "git-delta"    # pretty git diffs
brew "btop"         # system monitor
brew "lazydocker"   # docker TUI
brew "gh"           # GitHub CLI (gh dash via: gh extension install dlvhdr/gh-dash)
cask "ghostty"      # GPU terminal
